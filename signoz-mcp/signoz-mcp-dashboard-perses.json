  "spec": {
    "display": {
      "name": "SigNoz MCP Server",
      "description": "Operational dashboard for the signoz-mcp-server: tool-call rate and error rate, MCP method usage, OAuth events and failures, identity-cache health, execute_tool span latency, and log volume by severity. Use the $environment variable to scope to one or more tenant regions."
    },
    "variables": [],
    "panels": {
      "8daca8a5-d985-4ecf-81d8-a1b8ce6e168f": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "MCP Spans Error Rate"
          },
          "plugin": {
            "kind": "signoz/NumberPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 0,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": " service.name = 'signoz-mcp-server' has_error = true"
                          },
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 0,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": " service.name = 'signoz-mcp-server' has_error = false"
                          },
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "A / (A + B)"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
