{
  "uuid": "kong-gateway-v4-full",
  "title": "Kong Gateway - Official Monitoring",
  "description": "Enterprise-grade dashboard for Kong OSS/Enterprise using SigNoz v4 schema.",
  "tags": ["kong", "gateway", "api-management"],
  "data": {
    "variables": {
      "namespace": { "name": "namespace", "query": "label_values(kong_http_requests_total, namespace)", "type": "QUERY" },
      "service": { "name": "service", "query": "label_values(kong_http_requests_total, service)", "type": "QUERY" },
      "cluster": { "name": "cluster", "query": "label_values(kong_http_requests_total, cluster)", "type": "QUERY" }
    },
    "widgets": [
      { "title": "Total Requests", "type": "graph", "query": "sum(rate(kong_http_requests_total[5m]))", "unit": "req/s", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0} },
      { "title": "Active Connections", "type": "value", "query": "sum(kong_connections_active)", "unit": "conn", "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0} },
      { "title": "Kong Uptime", "type": "value", "query": "time() - kong_process_start_time_seconds", "unit": "s", "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0} },
      { "title": "P99 Request Latency", "type": "graph", "query": "histogram_quantile(0.99, sum(rate(kong_latency_ms_bucket[5m])) by (le, service))", "unit": "ms", "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6} },
      { "title": "Response Status Codes", "type": "graph", "query": "sum(rate(kong_http_requests_total[5m])) by (code)", "unit": "req/s", "gridPos": {"h": 6, "w": 12, "x": 12, "y": 6} }
    ]
  }
}