                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 0,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "has_error = 'true'  service.name in $service_name "
                          },
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 0,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "has_error = 'false'  llm.request.type = 'chat' service.name in $service_name "
                          },
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "A / (A+B)"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
