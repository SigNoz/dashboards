{
  "schemaVersion": "v6",
  "image": "data:image/svg+xml;base64,",
  "name": "web-vitals-monitoring-jq6xn1s4",
  "tags": [
    {
      "key": "tag",
      "value": "web-vitals"
    }
  ],
  "spec": {
    "display": {
      "name": "Web Vitals Monitoring",
      "description": "Real-time monitoring of key Web Vitals using traces to track user experience and page performance.\n\n"
    },
    "variables": [
      {
        "kind": "TextVariable",
        "spec": {
          "display": {
            "name": "service-name",
            "description": "Name to the service to display web vitals from."
          },
          "value": "",
          "constant": false,
          "name": "service-name"
        }
      }
    ],
    "panels": {
      "514c6591-1e77-4459-9c42-0d8827e68075": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "CLS - Cumulative Layout Shift",
            "description": "Measures visual stability. To provide a good user experience, pages should maintain a CLS of 0.1 or less."
          },
          "plugin": {
            "kind": "signoz/NumberPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "thresholds": [
                {
                  "value": 0.1,
                  "operator": "above",
                  "unit": "none",
                  "color": "Orange",
                  "format": "text"
                },
                {
                  "value": 0.25,
                  "operator": "above",
                  "unit": "none",
                  "color": "Red",
                  "format": "text"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "traces",
                    "source": "",
                    "aggregations": [
                      {
                        "expression": "avg(web_vital.value)"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "(service.name = $service-name AND web_vital.name = 'CLS')"
                    },
                    "groupBy": [],
                    "order": [],
                    "having": {
                      "expression": ""
                    },
                    "functions": [],
                    "legend": "FCP"
                  }
                }
              }
            }
          ]
        }
      },
      "59d65b85-c81f-49a9-8e15-92b9fafbd190": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "LCP - Largest Contentful Paint",
            "description": "Measures loading performance. To provide a good user experience, LCP should occur within 2.5 seconds of when the page first starts loading."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "ms",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": [
                {
                  "value": 2500,
                  "unit": "ms",
                  "color": "Orange",
                  "label": "Needs Improvement"
                },
                {
                  "value": 4000,
                  "unit": "ms",
                  "color": "Red",
                  "label": "Poor"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "traces",
                    "source": "",
                    "aggregations": [
                      {
                        "expression": "avg(web_vital.value)"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "(service.name = $service-name AND web_vital.name = 'LCP')"
                    },
                    "groupBy": [],
                    "order": [],
                    "having": {
                      "expression": ""
                    },
                    "functions": [],
                    "legend": "LCP"
                  }
                }
              }
            }
          ]
        }
      },
