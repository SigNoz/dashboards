{
  "schemaVersion": "v6",
  "name": "signoz-chat-pdf-performance-metrics-xpc19szw",
  "tags": [
    {
      "key": "tag",
      "value": "langchain"
    }
  ],
  "spec": {
    "display": {
      "name": "SigNoz Chat PDF Performance Metrics"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "userNames"
          },
          "defaultValue": [
            "Hans Gruber",
            "Lucy McClane",
            "John McClane",
            "0",
            "1",
            "2"
          ],
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT DISTINCT stringTagMap['traceloop.association.properties.user_id'] as userNames\nFROM signoz_traces.distributed_signoz_index_v2\nWHERE userNames != '' AND timestamp \u003e= now() - INTERVAL 1 DAY\n\n"
            }
          },
          "name": "userNames"
        }
      }
    ],
    "panels": {
      "54b18ffc-6547-41b5-a96d-83f8609f2785": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Latency"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "ms",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": null,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": [
                {
                  "value": 5000,
                  "unit": "ms",
                  "color": "Red",
                  "label": "5000"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "signoz_latency_sum",
                        "temporality": "",
                        "timeAggregation": "rate",
                        "spaceAggregation": "sum",
                        "reduceTo": "sum"
                      }
                    ],
                    "groupBy": [
                      {
                        "name": "service_name",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "bb864571-2bd8-4b00-8c1a-33ce9c427aa3": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Token Throughput"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "ops",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
