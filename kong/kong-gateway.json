    {
      "description": "Total HTTP requests handled by Kong Gateway",
      "fillSpans": false,
      "id": "widget-1",
      "isStacked": false,
      "nullZeroValues": "zero",
      "opacity": "1",
      "panelTypes": "value",
      "query": {
        "builder": {
          "queryData": [],
          "queryFormulas": []
        },
        "promql": [
          {
            "disabled": false,
            "legend": "Total Requests",
            "name": "A",
            "query": "sum(increase(kong_http_requests_total{namespace=~\"[[namespace]]\", service=~\"[[service]]\", deployment.environment=~\"[[deployment.environment]]\", cluster=~\"[[cluster]]\"}[$__rate_interval]))"
          }
        ],
        "queryType": "promql"
      },
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "title": "Total Requests",
      "type": "widget"
