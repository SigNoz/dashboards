        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name",
            "description": "Auto-discovered services (from metric labels)."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "service.name",
              "signal": "metrics"
