      "name": "cluster_name",
      "order": 1,
      "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'cluster_name'))\nFROM signoz_metrics.time_series_v4\nWHERE metric_name LIKE '%elasticsearch%'\nAND (unix_milli >= $__unixMilliStart() AND unix_milli <= $__unixMilliEnd())",
