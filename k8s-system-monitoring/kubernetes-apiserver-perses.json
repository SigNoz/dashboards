{
  "schemaVersion": "v6",
  "name": "kubernetes-api-server-4dtukmfo",
  "tags": [
    {
      "key": "tag",
      "value": "kubernetes"
    },
    {
      "key": "tag",
      "value": "control-plane"
    },
    {
      "key": "tag",
      "value": "apiserver"
