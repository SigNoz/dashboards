      "kubelet-discovery": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Auto-Discovered Kubelet Services"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "short",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "solid",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": "0s"
                }
              },
              "axes": {
                "softMin": null,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "kubelet_running_pods",
                        "temporality": "",
                        "timeAggregation": "latest",
                        "spaceAggregation": "sum",
                        "reduceTo": "last"
                      }
                    ],
                    "filter": {
                      "expression": "service.name IN $service.name AND k8s.cluster.name IN $k8s.cluster.name"
                    },
                    "groupBy": [
                      {
                        "name": "service.name",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    },
                    "legend": "{{service.name}}"
