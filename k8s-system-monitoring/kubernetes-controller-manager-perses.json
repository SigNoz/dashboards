  "spec": {
    "display": {
      "name": "Kubernetes Controller Manager",
      "description": "Standard control-plane view for kube-controller-manager workqueues, retries, and client request pressure."
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name",
            "description": "Auto-discovered services (from metric labels)."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "service.name",
              "signal": "metrics"
            }
          },
          "name": "service.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.cluster.name",
            "description": "Optional cluster label selector."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.cluster.name",
              "signal": "metrics"
            }
          },
          "name": "k8s.cluster.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "deployment_environment_name",
            "description": "Optional OTel environment label selector."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "deployment.environment.name",
              "signal": "metrics"
            }
          },
          "name": "deployment_environment_name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "deployment_environment",
            "description": "Optional legacy environment label selector."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "deployment.environment",
              "signal": "metrics"
            }
          },
          "name": "deployment_environment"
        }
      }
    ],
