  "spec": {
    "display": {
      "name": "Kubernetes API Server",
      "description": "Standard control-plane view for kube-apiserver using Prometheus/OpenTelemetry metrics."
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name",
            "description": "Auto-discovered services (from metric labels)."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "service.name",
              "signal": "metrics"
            }
          },
          "name": "service.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.cluster.name",
            "description": "Optional cluster label selector."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.cluster.name",
              "signal": "metrics"
            }
          },
          "name": "k8s.cluster.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "deployment_environment_name",
            "description": "Optional OTel environment label selector."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "deployment.environment.name",
              "signal": "metrics"
            }
          },
          "name": "deployment_environment_name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "deployment_environment",
            "description": "Optional legacy environment label selector."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "deployment.environment",
              "signal": "metrics"
            }
          },
          "name": "deployment_environment"
        }
      }
    ],
    "panels": {
      "apiserver-discovery": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Auto-Discovered API Services"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "reqps",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": null,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "apiserver_request_total",
                        "temporality": "",
                        "timeAggregation": "rate",
                        "spaceAggregation": "sum",
                        "reduceTo": "avg"
                      }
                    ],
                    "filter": {
                      "expression": "service.name IN $service.name AND k8s.cluster.name IN $k8s.cluster.name"
                    },
                    "groupBy": [
                      {
                        "name": "service.name",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    },
                    "legend": "{{service.name}}"
                  }
                }
              }
            }
          ]
        }
      },
