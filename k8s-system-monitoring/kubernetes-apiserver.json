      "id": "apiserver-discovery",
      "panelTypes": "graph",
      "query": {
        "builder": {
          "queryData": [
            {
              "aggregations": [
                {
                  "metricName": "apiserver_request_total",
                  "reduceTo": "avg",
                  "spaceAggregation": "sum",
                  "temporality": null,
                  "timeAggregation": "rate"
                }
              ],
              "dataSource": "metrics",
              "disabled": false,
              "expression": "A",
              "groupBy": [
                {
                  "dataType": "string",
                  "isColumn": false,
                  "key": "service.name",
                  "type": ""
                }
              ],
              "having": {
                "expression": ""
              },
              "legend": "{{service.name}}",
              "queryName": "A",
              "stepInterval": 60,
              "filter": {
                "expression": "service.name IN $service.name AND k8s.cluster.name IN $k8s.cluster.name"
              }
            }
          ],
          "queryFormulas": []
        },
        "queryType": "builder"
      },
