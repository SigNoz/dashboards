      "multiSelect": false,
      "name": "deployment.environment",
      "order": 0,
      "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'deployment.environment')) as `deployment.environment`\nFROM signoz_metrics.time_series_v4\nWHERE metric_name LIKE '%elasticsearch%'\nAND (unix_milli >= $__unixMilliStart() AND unix_milli <= $__unixMilliEnd())",
      "textboxValue": "",
      "type": "QUERY"
    },
