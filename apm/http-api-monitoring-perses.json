{
  "schemaVersion": "v6",
  "image": "data:image/svg+xml;base64,",
  "name": "http-api-monitoring-j7kuzm1y",
  "tags": [],
  "spec": {
    "display": {
      "name": "HTTP API Monitoring",
      "description": "Built on top of available HTTP attributes from opentelemetry: https://opentelemetry.io/docs/specs/semconv/attributes-registry/http/"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name",
            "description": ""
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "customAllValue": "",
          "capturingRegexp": "",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'service.name') AS `service.name` FROM signoz_metrics.time_series_v4_1day WHERE (metric_name = 'signoz_calls_total') AND (unix_milli \u003e= (toUnixTimestamp(now() - toIntervalDay(1)) * 1000)) GROUP BY `service.name`"
            }
          },
          "name": "service.name"
        }
      }
    ],
    "panels": {
      "470f834c-fa5e-457f-a85f-a0571767fa43": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "5xx Error Rate by Endpoint",
            "description": "Rate of HTTP 5xx server errors per endpoint"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "reqps",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "traces",
                    "source": "",
                    "aggregations": [
                      {
                        "expression": "rate()"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "serviceName IN $service.name AND spanKind = 'Server' AND httpRoute EXISTS AND responseStatusCode LIKE '5%'"
                    },
                    "groupBy": [
                      {
                        "name": "httpRoute",
                        "signal": "",
                        "fieldContext": "",
                        "fieldDataType": "string"
                      }
                    ],
                    "order": [],
                    "having": {
                      "expression": ""
                    },
                    "functions": [],
                    "legend": "{{httpRoute}}"
                  }
                }
              }
            }
          ]
        }
      },
