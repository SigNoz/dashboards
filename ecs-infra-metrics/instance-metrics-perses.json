  "spec": {
    "display": {
      "name": "Instance Metrics - ECS",
      "description": "Instance Metrics Dashboard of ECS EC2"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "ClusterName"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'ClusterName') as ClusterName\nFROM signoz_metrics.time_series_v4_1day\nWHERE metric_name = 'instance_cpu_utilization'\nGROUP BY ClusterName"
            }
          },
          "name": "ClusterName"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "AutoScalingGroupName"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'AutoScalingGroupName') as AutoScalingGroupName\nFROM signoz_metrics.time_series_v4_1day\nWHERE metric_name = 'instance_cpu_utilization' AND JSONExtractString(labels, 'ClusterName') = {{ .ClusterName }}\nGROUP BY AutoScalingGroupName"
            }
          },
          "name": "AutoScalingGroupName"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "InstanceId"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'InstanceId') as InstanceId\nFROM signoz_metrics.time_series_v4_1day\nWHERE metric_name = 'instance_cpu_utilization' AND JSONExtractString(labels, 'AutoScalingGroupName') = {{ .AutoScalingGroupName }}\nGROUP BY InstanceId"
            }
          },
          "name": "InstanceId"
        }
      }
    ],
