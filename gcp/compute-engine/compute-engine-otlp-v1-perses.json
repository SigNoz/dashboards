{
  "schemaVersion": "v6",
  "image": "data:image/svg+xml;base64,",
  "name": "gcp-compute-engine-dashboard-lpq9ksyr",
  "tags": [],
  "spec": {
    "display": {
      "name": "GCP Compute Engine Dashboard",
      "description": "This dashboard plots all the important metrics for GCP Compute Engine."
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "deployment.environment",
            "description": "The deployment environment for the service."
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'deployment.environment'))\nFROM signoz_metrics.time_series_v4\nWHERE metric_name like '%compute%'"
            }
          },
          "name": "deployment.environment"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "project_id",
            "description": "GCP Project ID"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'project_id'))\nFROM signoz_metrics.time_series_v4\nWHERE metric_name like '%compute%'"
            }
          },
          "name": "project_id"
        }
      }
    ],
    "panels": {
      "0413e9a9-c4bd-4e02-b849-9bfc098a4ebe": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Incoming I/O",
            "description": "Increase in the count of bytes received from the network."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": "0s"
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "compute.googleapis.com/instance/network/received_bytes_count",
                        "temporality": "",
                        "timeAggregation": "increase",
                        "spaceAggregation": "sum",
                        "reduceTo": "avg"
                      }
                    ],
                    "filter": {
                      "expression": "(deployment.environment = $deployment.environment AND project_id = $project_id)"
                    },
                    "groupBy": [
                      {
                        "name": "instance_id",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    },
                    "legend": "Instance ID: {{instance_id}}"
                  }
                }
              }
            }
          ]
        }
      },
