{
  "schemaVersion": "v6",
  "image": "data:image/svg+xml;base64,",
  "name": "db-calls-monitoring-0hkgjver",
  "tags": [],
  "spec": {
    "display": {
      "name": "DB Calls Monitoring",
      "description": "Built on top of available DB attributes from opentelemetry: https://opentelemetry.io/docs/specs/semconv/attributes-registry/db/"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'service.name') AS `service.name` FROM signoz_metrics.time_series_v4_1day WHERE (metric_name = 'signoz_calls_total') AND (unix_milli \u003e= (toUnixTimestamp(now() - toIntervalDay(1)) * 1000)) GROUP BY `service.name`"
            }
          },
          "name": "service.name"
        }
      }
    ],
    "panels": {
      "057b5e82-35ca-40fa-b8a3-c6f5d23433c0": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "DB Transaction Rate"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "reqps",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "traces",
                    "source": "",
                    "aggregations": [
                      {
                        "expression": "rate()"
                      }
                    ],
                    "filter": {
                      "expression": "(dbSystem EXISTS AND serviceName = $service.name) dbName EXISTS"
                    },
                    "groupBy": [
                      {
                        "name": "dbName",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    },
                    "legend": "{{dbName}}"
                  }
                }
              }
            }
          ]
        }
      },
      "7522011f-7111-4707-9686-bb052dd827a7": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "DB Error rate"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "percent",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 60,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "(dbSystem EXISTS AND serviceName = $service.name AND hasError = 'true') dbName EXISTS"
                          },
                          "groupBy": [
                            {
                              "name": "dbName",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 60,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "dbSystem EXISTS dbName EXISTS"
                          },
                          "groupBy": [
                            {
                              "name": "dbName",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "(A/B)",
                          "legend": "{{dbName}}"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
      "ba27811a-2716-4a25-9f84-dbf30896b2e8": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Top DB Statements"
          },
          "plugin": {
            "kind": "signoz/TablePanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "columnUnits": {
                  "B": "ns",
                  "C": "reqps"
                },
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 60,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "filter": {
                            "expression": "(dbSystem EXISTS AND serviceName = $service.name) dbName EXISTS AND db.statement EXISTS"
                          },
                          "groupBy": [
                            {
                              "name": "dbName",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "db.statement",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          },
                          "legend": "Total Calls"
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 60,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "p50(durationNano)"
                            }
                          ],
                          "filter": {
                            "expression": "(dbSystem EXISTS AND serviceName = $service.name) dbName EXISTS AND db.statement EXISTS"
                          },
                          "groupBy": [
                            {
                              "name": "dbName",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "db.statement",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          },
                          "legend": "Average Duration"
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "C",
                          "stepInterval": 60,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "rate()"
                            }
                          ],
                          "filter": {
                            "expression": "(dbSystem EXISTS AND serviceName = $service.name) dbName EXISTS AND db.statement EXISTS"
                          },
                          "groupBy": [
                            {
                              "name": "dbName",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "db.statement",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          },
                          "legend": "Rate"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
      "e3b48480-d15c-44eb-a054-13ffa59a9227": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Slowest DB Calls"
          },
          "plugin": {
            "kind": "signoz/ListPanel",
            "spec": {
              "selectFields": [
                {
                  "name": "body"
                },
                {
                  "name": "timestamp"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "raw",
              "spec": {
                "name": "B",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "B",
                    "stepInterval": 60,
                    "signal": "traces",
                    "source": "",
                    "filter": {
                      "expression": "(dbSystem EXISTS AND serviceName = $service.name)"
                    },
                    "order": [
                      {
                        "key": {
                          "name": "durationNano"
                        },
                        "direction": "desc"
                      }
                    ],
                    "limit": 10,
                    "having": {
                      "expression": ""
                    }
                  }
                }
              }
            }
          ]
        }
      }
    },
    "layouts": [
      {
        "kind": "Grid",
        "spec": {
          "items": [
            {
              "x": 0,
              "y": 0,
              "width": 6,
              "height": 6,
              "content": {
                "$ref": "#/spec/panels/057b5e82-35ca-40fa-b8a3-c6f5d23433c0"
              }
            },
            {
              "x": 6,
              "y": 0,
              "width": 6,
              "height": 6,
              "content": {
                "$ref": "#/spec/panels/ba27811a-2716-4a25-9f84-dbf30896b2e8"
              }
            },
            {
              "x": 6,
              "y": 6,
              "width": 6,
              "height": 6,
              "content": {
                "$ref": "#/spec/panels/7522011f-7111-4707-9686-bb052dd827a7"
              }
            },
            {
              "x": 0,
              "y": 12,
              "width": 12,
              "height": 7,
              "content": {
                "$ref": "#/spec/panels/e3b48480-d15c-44eb-a054-13ffa59a9227"
              }
            }
          ]
        }
      }
    ]
  }
}