{
    "uuid": "kong-monitoring-dashboard",
    "title": "Kong Gateway Monitoring",
    "panels": [
          {
                  "title": "Total Requests (RPS)",
                  "type": "graph",
                  "targets": [{"expr": "sum(rate(kong_http_requests_total[5m]))"}]
          },
          {
                  "title": "P99 Latency",
                  "type": "graph",
                  "targets": [{"expr": "histogram_quantile(0.99, sum(rate(kong_http_latency_ms_bucket[5m])) by (le))"}]
          },
          {
                  "title": "Bandwidth (Bytes In/Out)",
                  "type": "graph",
                  "targets": [
                            {"expr": "sum(rate(kong_bandwidth_bytes_total[5m]))"}
                  ]
          },
          {
                  "title": "Plugin Errors",
                  "type": "graph",
                  "targets": [{"expr": "sum(rate(kong_plugin_errors_total[5m]))"}]
          }
    ]
}
