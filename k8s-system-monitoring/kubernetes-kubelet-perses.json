          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.cluster.name",
              "signal": "metrics"
            }
          },
          "name": "k8s.cluster.name"
        }
      },
      {
        "kind": "ListVariable",
