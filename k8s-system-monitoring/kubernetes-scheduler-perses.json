              "kind": "scalar",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "scheduler_schedule_attempts_total",
                        "temporality": "",
                        "timeAggregation": "rate",
                        "spaceAggregation": "sum",
                        "reduceTo": "avg"
                      }
                    ],
                    "filter": {
                      "expression": "service.name IN $service.name AND k8s.cluster.name IN $k8s.cluster.name"
                    },
                    "having": {
                      "expression": ""
