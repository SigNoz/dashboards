{
  "schemaVersion": "v6",
  "image": "data:image/svg+xml;base64,",
  "name": "aws-sqs-prometheus-7rbgnggz",
  "tags": [
    {
      "key": "tag",
      "value": "SQS"
    },
    {
      "key": "tag",
      "value": "AWS"
    },
    {
      "key": "tag",
      "value": "Prometheus"
    }
  ],
  "spec": {
    "display": {
      "name": "AWS SQS Prometheus",
      "description": "Dashboard is built on the provided metrics by Third-party prometheus exporters \n( https://github.com/jmal98/sqs-exporter )"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "region",
            "description": "Select AWS region"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "customAllValue": "",
          "capturingRegexp": "",
          "sort": "none",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'region'))\nFROM signoz_metrics.time_series_v4\nWHERE metric_name like '%sqs%'"
            }
          },
          "name": "region"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "queue.name",
            "description": "Select the AWS SQS"
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "customAllValue": "",
          "capturingRegexp": "",
          "sort": "none",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'queue'))\nFROM signoz_metrics.time_series_v4\nWHERE metric_name like '%sqs%'"
            }
          },
          "name": "queue.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "deployment.environment",
            "description": "Select SigNoz across different environments"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "customAllValue": "",
          "capturingRegexp": "",
          "sort": "none",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'deployment.environment')) as `deployment.environment`\nFROM signoz_metrics.time_series_v4\nWHERE (metric_name LIKE '%otelcol%')\n  AND (unix_milli \u003e= (toUnixTimestamp(now() - toIntervalDay(1)) * 1000)) \nGROUP BY `deployment.environment`"
            }
          },
          "name": "deployment.environment"
        }
      }
    ],
    "panels": {
      "3abd2f84-6ba4-4107-bb13-097e4baf0727": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Approximate Number Of Messages Not Visible",
            "description": "Approximate number of messages that have not timed-out and aren't deleted"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "sqs_approximatenumberofmessagesnotvisible",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "avg",
                        "reduceTo": "avg"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "(queue IN $queue.name AND deployment.environment = $deployment.environment AND cloud.region = $region)"
                    },
                    "groupBy": [
                      {
                        "name": "queue",
                        "signal": "",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      }
                    ],
                    "order": [],
                    "having": {
                      "expression": ""
                    },
                    "functions": [],
                    "legend": "{{queue}}"
                  }
                }
              }
            }
          ]
        }
      },
