                            "expression": "type = 'cacheRead'"
                          },
                          "groupBy": [],
                          "order": [],
                          "having": {
                            "expression": ""
                          },
                          "functions": [],
                          "legend": "Cache Read"
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 60,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "opencode.token.usage",
                              "temporality": "",
                              "timeAggregation": "rate",
                              "spaceAggregation": "sum",
                              "reduceTo": "sum"
                            }
                          ],
                          "disabled": false,
                          "filter": {
                            "expression": "type = 'input'"
