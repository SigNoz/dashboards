      "dynamicVariablesSource": "Metrics",
      "multiSelect": true,
      "showALLOption": true,
      "sort": "ASC",
      "textboxValue": "",
      "customValue": "",
      "order": 0
    },
    "kind": {
      "id": "kind",
      "name": "kind",
      "type": "CUSTOM",
