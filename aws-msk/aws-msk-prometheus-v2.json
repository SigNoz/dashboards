  "title": "AWS MSK Cluster Monitoring - Prometheus",
  "uploadedGrafana": false,
  "uuid": "d4e5f6a7-b8c9-4d0e-af1b-2c3d4e5f6a7b",
  "variables": {
    "e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b": {
      "allSelected": false,
      "customValue": "",
      "description": "Deployment environment filter",
      "id": "e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b",
      "key": "e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b",
      "modificationUUID": "f2a3b4c5-d6e7-4f8a-9b0c-1d2e3f4a5b6c",
      "multiSelect": false,
      "name": "deployment.environment",
      "order": 0,
      "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'deployment.environment')) as `deployment.environment`\nFROM signoz_metrics.time_series_v4\nWHERE metric_name LIKE '%kafka%'\n  AND unix_milli >= (toUnixTimestamp(now() - toIntervalDay(1)) * 1000)\nGROUP BY `deployment.environment`",
      "showALLOption": true,
      "sort": "DISABLED",
      "textboxValue": "",
      "type": "QUERY"
    },
    "a3b4c5d6-e7f8-4a9b-0c1d-2e3f4a5b6c7d": {
      "allSelected": false,
      "customValue": "",
      "description": "Kafka broker instance",
      "id": "a3b4c5d6-e7f8-4a9b-0c1d-2e3f4a5b6c7d",
      "key": "a3b4c5d6-e7f8-4a9b-0c1d-2e3f4a5b6c7d",
      "modificationUUID": "b4c5d6e7-f8a9-4b0c-1d2e-3f4a5b6c7d8e",
      "multiSelect": true,
      "name": "broker",
      "order": 1,
      "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'instance')) as `broker`\nFROM signoz_metrics.time_series_v4\nWHERE metric_name LIKE '%kafka_server%'",
      "showALLOption": true,
      "sort": "DISABLED",
      "textboxValue": "",
      "type": "QUERY"
    },
    "c5d6e7f8-a9b0-4c1d-2e3f-4a5b6c7d8e9f": {
      "allSelected": false,
      "customValue": "",
      "description": "Kafka topic name",
      "id": "c5d6e7f8-a9b0-4c1d-2e3f-4a5b6c7d8e9f",
      "key": "c5d6e7f8-a9b0-4c1d-2e3f-4a5b6c7d8e9f",
      "modificationUUID": "d6e7f8a9-b0c1-4d2e-3f4a-5b6c7d8e9f0a",
      "multiSelect": true,
      "name": "topic",
      "order": 2,
      "queryValue": "SELECT DISTINCT(JSONExtractString(labels, 'topic')) as `topic`\nFROM signoz_metrics.time_series_v4\nWHERE metric_name LIKE '%kafka_server_BrokerTopicMetrics%'",
      "showALLOption": true,
      "sort": "DISABLED",
      "textboxValue": "",
      "type": "QUERY"
    }
  },
