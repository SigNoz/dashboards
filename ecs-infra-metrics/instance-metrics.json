      "order": 2,
      "queryValue": "SELECT JSONExtractString(labels, 'InstanceId') as InstanceId\nFROM signoz_metrics.time_series_v4_1day\nWHERE metric_name = 'instance_cpu_utilization' AND JSONExtractString(labels, 'AutoScalingGroupName') = {{ .AutoScalingGroupName }}\nGROUP BY InstanceId",
      "showALLOption": false,
      "sort": "ASC",
      "textboxValue": "",
