{
  "schemaVersion": "v6",
  "name": "apache-monitoring-dashboard-bxp2udub",
  "tags": [],
  "spec": {
    "display": {
      "name": "Apache Monitoring Dashboard"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "apache.server.name"
          },
          "defaultValue": "localhost",
          "allowAllValue": false,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'apache.server.name') as `apache.server.name`\nFROM signoz_metrics.time_series_v4_1day\nWHERE metric_name = 'apache.cpu.load'\nGROUP BY `apache.server.name`"
            }
          },
          "name": "apache.server.name"
        }
      }
    ],
