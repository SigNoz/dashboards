      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "host_name",
            "description": "List of hosts sending Redis metrics"
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "host.name",
              "signal": "metrics"
            }
          },
          "name": "host_name"
        }
      }
    ],
    "panels": {
