      "579f8e38-9b07-4c73-ae6c-db82b65ea4b2": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Number of Conversations Below Threshold",
            "description": ""
          },
          "plugin": {
            "kind": "signoz/NumberPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/ClickHouseSQL",
                  "spec": {
                    "name": "A",
                    "query": "SELECT\n    count() AS conversations_below_threshold\nFROM (\n    SELECT\n        traceID,\n        count(*) AS turn_count\n    FROM signoz_traces.distributed_signoz_index_v3\n    WHERE serviceName IN $service_name\n      AND name = 'turn'\n    GROUP BY traceID\n    HAVING turn_count \u003c toUInt64($turns_threshold)\n)\n",
                    "disabled": false,
                    "legend": ""
                  }
                }
              }
            }
          ],
          "links": []
        }
      },
