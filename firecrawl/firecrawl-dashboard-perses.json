      "error-rate": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Error Rate"
          },
          "plugin": {
            "kind": "signoz/NumberPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "unit": "percentunit",
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 60,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "firecrawl.operation EXISTS AND has_error = true"
                          },
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 60,
                          "signal": "traces",
                          "source": "",
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "firecrawl.operation EXISTS AND has_error = false"
                          },
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "A / (A + B)"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
