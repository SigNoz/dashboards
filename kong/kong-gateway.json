  "variables": {
    "var-namespace": {
      "allSelected": true,
      "customValue": "",
      "description": "Kubernetes namespace where Kong is deployed",
      "id": "var-namespace",
      "modificationUUID": "namespace-uuid-001",
      "multiSelect": true,
      "name": "namespace",
      "order": 0,
      "queryValue": "SELECT JSONExtractString(labels, 'namespace') AS namespace\nFROM signoz_metrics.distributed_time_series_v4_1day\nWHERE metric_name = 'kong_http_requests_total'\nGROUP BY namespace",
      "selectedValue": [""],
      "showALLOption": true,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    },
    "var-service": {
      "allSelected": true,
      "customValue": "",
      "description": "Kong service name",
      "id": "var-service",
      "modificationUUID": "service-uuid-002",
      "multiSelect": true,
      "name": "service",
      "order": 1,
      "queryValue": "SELECT JSONExtractString(labels, 'service') AS service\nFROM signoz_metrics.distributed_time_series_v4_1day\nWHERE metric_name = 'kong_http_requests_total'\nGROUP BY service",
      "selectedValue": [""],
      "showALLOption": true,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    },
    "var-deployment-environment": {
      "allSelected": true,
      "customValue": "",
      "description": "Deployment environment (production, staging, development)",
      "id": "var-deployment-environment",
      "modificationUUID": "env-uuid-003",
      "multiSelect": true,
      "name": "deployment.environment",
      "order": 2,
      "queryValue": "SELECT JSONExtractString(labels, 'deployment.environment') AS deployment.environment\nFROM signoz_metrics.distributed_time_series_v4_1day\nWHERE metric_name = 'kong_http_requests_total'\nGROUP BY deployment.environment",
      "selectedValue": [""],
      "showALLOption": true,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    },
    "var-cluster": {
      "allSelected": true,
      "customValue": "",
      "description": "Kubernetes cluster name",
      "id": "var-cluster",
      "modificationUUID": "cluster-uuid-004",
      "multiSelect": true,
      "name": "cluster",
      "order": 3,
      "queryValue": "SELECT JSONExtractString(labels, 'cluster') AS cluster\nFROM signoz_metrics.distributed_time_series_v4_1day\nWHERE metric_name = 'kong_http_requests_total'\nGROUP BY cluster",
      "selectedValue": [""],
      "showALLOption": true,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    }
  },
