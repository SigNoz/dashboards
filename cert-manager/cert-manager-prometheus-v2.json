      "name": "namespace",
      "order": 0,
      "queryValue": "SELECT DISTINCT JSONExtractString(labels, 'namespace') FROM signoz_metrics.distributed_time_series_v4 WHERE metric_name='certmanager_certificate_ready_status' AND fingerprint GLOBAL IN (SELECT DISTINCT fingerprint FROM signoz_metrics.distributed_samples_v4 WHERE metric_name='certmanager_certificate_ready_status' AND unix_milli>toUnixTimestamp(now() - INTERVAL 15 MINUTE)*1000)",
      "selectedValue": "",
      "showALLOption": true,
      "sort": "DISABLED",
