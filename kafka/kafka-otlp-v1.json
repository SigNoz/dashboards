      "name": "deployment.environment",
      "order": 0,
      "queryValue": "SELECT JSONExtractString(labels, 'deployment.environment') AS `deployment.environment`\nFROM signoz_metrics.distributed_time_series_v4_1day\nWHERE metric_name = 'kafka.brokers'\nGROUP BY `deployment.environment`",
