    "panels": {
      "1406e6b6-0c99-46d4-9782-530f6e7e053a": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Pod filesystem usage"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "percentunit",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": "0s"
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 60,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "k8s.pod.filesystem.available",
                              "temporality": "",
                              "timeAggregation": "avg",
                              "spaceAggregation": "sum",
                              "reduceTo": "sum"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "(k8s.cluster.name IN $k8s.cluster.name  AND k8s.node.name IN $k8s.node.name AND k8s.namespace.name IN $k8s.namespace.name)"
                          },
                          "groupBy": [
                            {
                              "name": "k8s.node.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "k8s.namespace.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "k8s.pod.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 60,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "k8s.pod.filesystem.capacity",
                              "temporality": "",
                              "timeAggregation": "avg",
                              "spaceAggregation": "sum",
                              "reduceTo": "sum"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "(k8s.cluster.name IN $k8s.cluster.name  AND k8s.node.name IN $k8s.node.name AND k8s.namespace.name IN $k8s.namespace.name)"
                          },
                          "groupBy": [
                            {
                              "name": "k8s.node.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "k8s.namespace.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "k8s.pod.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          }
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "(B-A)/B",
                          "legend": "{{k8s.node.name}}-{{k8s.namespace.name}}-{{k8s.pod.name}}"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
