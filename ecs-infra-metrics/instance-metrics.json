      "multiSelect": false,
      "name": "ClusterName",
      "order": 0,
      "queryValue": "SELECT JSONExtractString(labels, 'ClusterName') as ClusterName\nFROM signoz_metrics.time_series_v4_1day\nWHERE metric_name = 'instance_cpu_utilization'\nGROUP BY ClusterName",
      "showALLOption": false,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    },
    "d81ed133-d75f-456c-859e-e78770dd7188": {
