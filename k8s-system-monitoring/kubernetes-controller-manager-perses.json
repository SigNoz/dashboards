      "cm-goroutines": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Go Routines"
          },
          "plugin": {
            "kind": "signoz/NumberPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "unit": "short",
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "go_goroutines",
                        "temporality": "",
                        "timeAggregation": "latest",
                        "spaceAggregation": "sum",
                        "reduceTo": "last"
                      }
                    ],
                    "filter": {
                      "expression": "service.name IN $service.name AND k8s.cluster.name IN $k8s.cluster.name"
                    },
                    "having": {
                      "expression": ""
                    },
                    "legend": "goroutines"
                  }
                }
              }
            }
          ]
        }
      },
