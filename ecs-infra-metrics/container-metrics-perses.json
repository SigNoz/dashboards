  ],
  "spec": {
    "display": {
      "name": "Container Metrics - ECS",
      "description": "Container Metrics Dashboard of ECS using sidecar"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "ClusterName"
          },
          "defaultValue": "default",
          "allowAllValue": false,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'aws.ecs.cluster.name') AS `aws.ecs.cluster.name` FROM signoz_metrics.time_series_v4_1day WHERE metric_name = 'ecs.task.cpu.utilized' GROUP BY `aws.ecs.cluster.name`"
            }
          },
          "name": "ClusterName"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "ServiceName"
          },
          "defaultValue": "default",
          "allowAllValue": false,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT JSONExtractString(labels, 'aws.ecs.service.name') AS `aws.ecs.service.name` FROM signoz_metrics.time_series_v4_1day WHERE metric_name = 'ecs.task.cpu.utilized' AND JSONExtractString(labels, 'aws.ecs.cluster.name') = $ClusterName GROUP BY `aws.ecs.service.name`"
            }
          },
          "name": "ServiceName"
        }
      }
    ],
    "panels": {
