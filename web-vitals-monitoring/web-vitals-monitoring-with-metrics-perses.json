  "spec": {
    "display": {
      "name": "Web Vitals Monitoring",
      "description": "Real-time monitoring of key Web Vitals metrics to track user experience and page performance."
    },
    "variables": [
      {
        "kind": "TextVariable",
        "spec": {
          "display": {
            "name": "service-name",
            "description": "Name of the relevant service"
          },
          "value": "signoz-web",
          "constant": false,
          "name": "service-name"
        }
      }
    ],
    "panels": {
      "09588353-8b51-4483-8461-636561618d24": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Time To First Byte",
            "description": "Measures the time the browser waits to receive the first byte of response from the server."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "ms",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": [
                {
                  "value": 200,
                  "unit": "ms",
                  "color": "Orange",
                  "label": "Needs Improvement"
                },
                {
                  "value": 600,
                  "unit": "ms",
                  "color": "Red",
                  "label": "Poor"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "ttfb.bucket",
                        "temporality": "",
                        "timeAggregation": "",
                        "spaceAggregation": "p90",
                        "reduceTo": "avg"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "service.name = $service-name"
                    },
                    "groupBy": [],
                    "order": [],
                    "having": {
                      "expression": ""
                    },
                    "functions": [],
                    "legend": "TTFB"
                  }
                }
              }
            }
          ]
        }
      },
