      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name",
            "description": "Auto-discovered services (from metric labels)."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "service.name",
              "signal": "metrics"
            }
          },
          "name": "service.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.cluster.name",
            "description": "Optional cluster label selector."
