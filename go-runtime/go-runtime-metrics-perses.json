    "display": {
      "name": "Go Runtime Metrics",
      "description": "Go runtime metrics dashboard for monitoring memory, goroutines, and scheduler performance"
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name"
          },
          "allowAllValue": true,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "service.name",
              "signal": "metrics"
            }
          },
          "name": "service.name"
        }
      }
    ],
    "panels": {
      "22222222-0000-4000-8000-000000000001": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Memory Limit (GOMEMLIMIT)",
            "description": "Go runtime memory limit configured by the user, if a limit exists (go.memory.limit)."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "bytes",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 0,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "go.memory.limit",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "avg",
                        "reduceTo": "avg"
                      }
                    ],
                    "filter": {
                      "expression": "service.name IN $service.name"
                    },
                    "having": {
                      "expression": ""
                    },
                    "legend": "limit"
                  }
                }
              }
            }
          ]
        }
      },
