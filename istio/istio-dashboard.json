      "opacity": "1",
      "panelTypes": "value",
      "query": {
        "clickhouse_sql": [{"name": "A", "legend": "", "disabled": false, "query": ""}],
        "promql": [
          {
            "name": "A",
            "query": "round(sum(irate(istio_requests_total{destination_workload_namespace=~\"$namespace\", reporter=\"destination\"}[5m])), 0.001)",
