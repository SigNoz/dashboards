{
  "schemaVersion": "v6",
  "image": "data:image/svg+xml;base64,",
  "name": "kubernetes-pod-metrics-detailed-v2z5scgh",
  "tags": [
    {
      "key": "tag",
      "value": "pod"
    },
    {
      "key": "tag",
      "value": "k8s"
    }
  ],
  "spec": {
    "display": {
      "name": "Kubernetes Pod Metrics - Detailed",
      "description": "This dashboard uses the Kubernetes pod metrics collected from the kubeletstats receiver to show CPU, Memory (usage, RSS, working set), Filesystem, and Network I/O \u0026 errors per pod across namespaces."
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.cluster.name",
            "description": "Name of the cluster"
          },
          "allowAllValue": true,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.cluster.name",
              "signal": ""
            }
          },
          "name": "k8s.cluster.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.node.name",
            "description": "The k8s node name."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.node.name",
              "signal": ""
            }
          },
          "name": "k8s.node.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.namespace.name",
            "description": "The k8s namespace name."
          },
          "allowAllValue": true,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.namespace.name",
              "signal": ""
            }
          },
          "name": "k8s.namespace.name"
        }
      }
    ],
    "panels": {
      "1f8965fb-5ad1-4679-9d28-9bd31d4e4cac": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Pod network errors"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": "0s"
                }
              },
              "axes": {
                "softMin": null,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "k8s.pod.network.errors",
                        "temporality": "",
                        "timeAggregation": "rate",
                        "spaceAggregation": "sum",
                        "reduceTo": "sum"
                      }
                    ],
                    "filter": {
                      "expression": "(k8s.cluster.name IN $k8s.cluster.name  AND k8s.node.name IN $k8s.node.name AND k8s.namespace.name IN $k8s.namespace.name)"
                    },
                    "groupBy": [
                      {
                        "name": "k8s.node.name",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "interface",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "direction",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "k8s.namespace.name",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "k8s.pod.name",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    },
                    "legend": "{{k8s.namespace.name}}-{{k8s.pod.name}}-{{interface}}-{{direction}}"
                  }
                }
              }
            }
          ]
        }
      },
