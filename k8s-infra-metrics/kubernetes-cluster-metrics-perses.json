{
  "schemaVersion": "v6",
  "name": "kubernetes-cluster-metrics-nd4t8ogx",
  "tags": [
    {
      "key": "tag",
      "value": "k8s"
    },
    {
      "key": "tag",
      "value": "cluster"
    },
    {
      "key": "tag",
      "value": "k8sclusterreceiver"
    }
  ],
  "spec": {
    "display": {
      "name": "Kubernetes Cluster Metrics",
      "description": "This dashboard uses the metrics sent using `k8sclusterreceiver` to show the desired and currently running pods for deployments, daemonsets, statefulset, replicasets and pods count by phase."
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.cluster.name",
            "description": "Name of the cluster"
          },
          "allowAllValue": true,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.cluster.name",
              "signal": ""
            }
          },
          "name": "k8s.cluster.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "k8s.namespace.name",
            "description": "The k8s namespace name."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "k8s.namespace.name",
              "signal": ""
            }
          },
          "name": "k8s.namespace.name"
        }
      }
    ],
    "panels": {
      "50a86ebc-f028-44bf-93f4-a62cc0ba8dd9": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Deployments available and desired"
          },
          "plugin": {
            "kind": "signoz/TablePanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "columnUnits": {
                  "A": "",
                  "B": ""
                },
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 0,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "k8s.deployment.available",
                              "temporality": "",
                              "timeAggregation": "latest",
                              "spaceAggregation": "sum",
                              "reduceTo": "last"
                            }
                          ],
                          "filter": {
                            "expression": "(k8s.cluster.name IN $k8s.cluster.name AND k8s.namespace.name IN $k8s.namespace.name)"
                          },
                          "groupBy": [
                            {
                              "name": "k8s.deployment.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          },
                          "legend": "available"
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 0,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "k8s.deployment.desired",
                              "temporality": "",
                              "timeAggregation": "latest",
                              "spaceAggregation": "sum",
                              "reduceTo": "last"
                            }
                          ],
                          "filter": {
                            "expression": "(k8s.cluster.name IN $k8s.cluster.name AND k8s.namespace.name IN $k8s.namespace.name)"
                          },
                          "groupBy": [
                            {
                              "name": "k8s.deployment.name",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "having": {
                            "expression": ""
                          },
                          "legend": "desired"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
      "7c4b1efb-8b3a-4a28-927d-f7fe9fb124e8": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Pod phase by namespace"
          },
          "plugin": {
            "kind": "signoz/TablePanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "columnUnits": {
                  "Failed": "",
                  "Pending": "",
                  "Running": "",
                  "Succeeded": "",
                  "Unknown": ""
                },
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/ClickHouseSQL",
                  "spec": {
                    "name": "A",
                    "query": "SELECT ts.resource_attrs['k8s.namespace.name'] AS `k8s.namespace.name`, countIf(toInt32(s.last_value) = 1) AS Pending, countIf(toInt32(s.last_value) = 2) AS Running, countIf(toInt32(s.last_value) = 3) AS Succeeded, countIf(toInt32(s.last_value) = 4) AS Failed, countIf(toInt32(s.last_value) = 5) AS Unknown FROM (SELECT fingerprint, argMax(value, unix_milli) AS last_value FROM signoz_metrics.distributed_samples_v4 WHERE metric_name = 'k8s.pod.phase' AND unix_milli \u003e= $end_timestamp_ms - 600000 AND unix_milli \u003c $end_timestamp_ms GROUP BY fingerprint) AS s INNER JOIN (SELECT DISTINCT fingerprint, resource_attrs FROM signoz_metrics.distributed_time_series_v4_6hrs WHERE metric_name = 'k8s.pod.phase' AND temporality = 'Unspecified' AND resource_attrs['k8s.cluster.name'] = $k8s.cluster.name) AS ts USING fingerprint GROUP BY `k8s.namespace.name` ORDER BY Running DESC",
                    "disabled": false
                  }
                }
              }
            }
          ]
        }
      },
