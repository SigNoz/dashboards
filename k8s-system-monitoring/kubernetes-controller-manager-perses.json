{
  "schemaVersion": "v6",
  "name": "kubernetes-controller-manager-6jni5win",
  "tags": [
    {
      "key": "tag",
      "value": "kubernetes"
    },
    {
      "key": "tag",
      "value": "control-plane"
    },
    {
      "key": "tag",
      "value": "controller-manager"
    },
    {
      "key": "tag",
      "value": "prometheus"
    }
