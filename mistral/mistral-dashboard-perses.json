          },
          "name": "language"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "llm_model",
            "description": "Model name being used in Mistral ai call"
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "llm.model_name",
              "signal": ""
            }
          },
          "name": "llm_model"
        }
      }
