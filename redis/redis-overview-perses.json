              "visualization": {
                "timePreference": "global_time",
                "fillSpans": true
              },
              "formatting": {
                "unit": "ops",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": "0s"
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "redis.commands",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "sum",
                        "reduceTo": "sum"
                      }
                    ],
                    "filter": {
                      "expression": "host.name IN $host_name"
                    },
                    "having": {
                      "expression": ""
                    },
                    "legend": "ops/s"
                  }
                }
              }
            }
