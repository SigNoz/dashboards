              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "traces",
                    "source": "",
                    "aggregations": [
                      {
                        "expression": "rate_sum(llm.usage.completion_tokens)"
                      }
                    ],
                    "filter": {
                      "expression": "traceloop.association.properties.user_id IN $.userNames serviceName EXISTS"
                    },
                    "groupBy": [
                      {
                        "name": "serviceName",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    }
                  }
                }
              }
            }
          ]
        }
      },
