  "widgets": [
    {
      "id": "row_overview",
      "panelTypes": "row",
      "title": "Overview"
    },
    {
      "id": "v_open_conn",
      "panelTypes": "value",
      "title": "Open Connections",
      "description": "Current backend connections across all session states, summed from planetscale_postgres_connection_state.",
      "yAxisUnit": "none",
      "thresholds": [],
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "metrics",
              "expression": "A",
              "stepInterval": 60,
              "aggregations": [
                { "metricName": "planetscale_postgres_connection_state", "temporality": "unspecified", "timeAggregation": "avg", "spaceAggregation": "sum" }
              ],
              "filter": { "expression": "planetscale_database_branch_id IN $branch AND planetscale_role IN $role" }
            }
          ],
          "queryFormulas": []
        },
        "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
        "clickhouse_sql": [{ "name": "A", "query": "", "legend": "", "disabled": false }]
      }
    },
    {
      "id": "v_conn_util",
      "panelTypes": "value",
      "title": "Connection Utilization",
      "description": "Open connections divided by max_connections.",
      "yAxisUnit": "percent",
      "thresholds": [
        { "index": "t0", "thresholdValue": 90, "thresholdFormat": "Background", "thresholdOperator": ">", "thresholdColor": "#e53935", "thresholdUnit": "percent", "thresholdLabel": "" }
      ],
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "metrics",
              "expression": "A",
              "disabled": true,
              "stepInterval": 60,
              "aggregations": [
                { "metricName": "planetscale_postgres_connection_state", "temporality": "unspecified", "timeAggregation": "avg", "spaceAggregation": "sum" }
              ],
              "filter": { "expression": "planetscale_database_branch_id IN $branch AND planetscale_role IN $role" }
            },
            {
              "queryName": "B",
              "dataSource": "metrics",
              "expression": "B",
              "disabled": true,
              "stepInterval": 60,
              "aggregations": [
                { "metricName": "planetscale_postgres_settings_max_connections", "temporality": "unspecified", "timeAggregation": "latest", "spaceAggregation": "sum" }
              ],
              "filter": { "expression": "planetscale_database_branch_id IN $branch AND planetscale_role IN $role" }
            }
          ],
          "queryFormulas": [
            { "queryName": "F1", "expression": "A / B * 100" }
          ]
        },
        "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
        "clickhouse_sql": [{ "name": "A", "query": "", "legend": "", "disabled": false }]
      }
    },
    {
      "id": "v_commit_rate",
      "panelTypes": "value",
      "title": "Commit Throughput",
      "description": "Committed transactions per second from planetscale_postgres_database_xact_commit_total.",
      "yAxisUnit": "none",
      "thresholds": [],
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "metrics",
              "expression": "A",
              "stepInterval": 60,
              "aggregations": [
                { "metricName": "planetscale_postgres_database_xact_commit_total", "temporality": "cumulative", "timeAggregation": "rate", "spaceAggregation": "sum" }
              ],
              "filter": { "expression": "planetscale_database_branch_id IN $branch AND planetscale_role IN $role" }
            }
          ],
          "queryFormulas": []
        },
        "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
        "clickhouse_sql": [{ "name": "A", "query": "", "legend": "", "disabled": false }]
      }
    },
    {
      "id": "v_replica_lag",
      "panelTypes": "value",
      "title": "WAL Archive Lag",
      "description": "WAL bytes waiting for archive, measured as current LSN minus last archived LSN. Rising values mean archiving has fallen behind.",
      "yAxisUnit": "bytes",
      "thresholds": [],
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "metrics",
              "expression": "A",
              "stepInterval": 60,
              "aggregations": [
                { "metricName": "planetscale_postgres_wal_archiver_lag_bytes", "temporality": "unspecified", "timeAggregation": "max", "spaceAggregation": "max" }
              ],
              "filter": { "expression": "planetscale_database_branch_id IN $branch AND planetscale_role IN $role" }
            }
          ],
          "queryFormulas": []
        },
        "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
        "clickhouse_sql": [{ "name": "A", "query": "", "legend": "", "disabled": false }]
      }
    },
    {
      "id": "v_storage_used",
      "panelTypes": "value",
      "title": "Storage Used",
      "description": "Used volume percentage, calculated as (capacity - available) / capacity.",
      "yAxisUnit": "percent",
      "thresholds": [
        { "index": "t0", "thresholdValue": 85, "thresholdFormat": "Background", "thresholdOperator": ">", "thresholdColor": "#e53935", "thresholdUnit": "percent", "thresholdLabel": "" }
      ],
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "metrics",
              "expression": "A",
              "disabled": true,
              "stepInterval": 60,
              "aggregations": [
                { "metricName": "planetscale_volume_capacity_bytes", "temporality": "unspecified", "timeAggregation": "latest", "spaceAggregation": "max" }
              ],
              "filter": { "expression": "planetscale_database_branch_id IN $branch AND planetscale_role IN $role" }
            },
            {
              "queryName": "B",
              "dataSource": "metrics",
              "expression": "B",
              "disabled": true,
              "stepInterval": 60,
              "aggregations": [
                { "metricName": "planetscale_volume_available_bytes", "temporality": "unspecified", "timeAggregation": "latest", "spaceAggregation": "max" }
              ],
              "filter": { "expression": "planetscale_database_branch_id IN $branch AND planetscale_role IN $role" }
            }
          ],
          "queryFormulas": [
            { "queryName": "F1", "expression": "(A - B) / A * 100" }
          ]
        },
        "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
        "clickhouse_sql": [{ "name": "A", "query": "", "legend": "", "disabled": false }]
      }
    },
