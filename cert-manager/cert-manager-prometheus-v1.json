      "multiSelect": false,
      "name": "namespace",
      "order": 0,
      "queryValue": "SELECT DISTINCT JSONExtractString(labels, 'namespace')\nFROM signoz_metrics.distributed_time_series_v4\nWHERE metric_name='certmanager_certificate_ready_status' AND fingerprint GLOBAL IN\n(\n  SELECT DISTINCT fingerprint FROM signoz_metrics.distributed_samples_v4 WHERE\n  metric_name='certmanager_certificate_ready_status' AND unix_milli>toUnixTimestamp(now() - INTERVAL 5 MINUTE)*1000\n)",
      "selectedValue": "",
      "showALLOption": false,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    },
    "64f31ea0-19f2-4b7e-90d4-604370a6d2e1": {
      "allSelected": false,
      "customValue": "",
      "description": "Issuer or ClusterIssuer name",
      "id": "64f31ea0-19f2-4b7e-90d4-604370a6d2e1",
      "modificationUUID": "cf6bcf34-7deb-4cb5-9de8-7f3900e3d1d6",
      "multiSelect": false,
      "name": "issuer",
      "order": 1,
      "queryValue": "SELECT DISTINCT JSONExtractString(labels, 'issuer_name')\nFROM signoz_metrics.distributed_time_series_v4\nWHERE metric_name='certmanager_certificate_ready_status'\nAND JSONExtractString(labels, 'namespace')={{.namespace}}\nAND fingerprint GLOBAL IN\n(\n  SELECT DISTINCT fingerprint FROM signoz_metrics.distributed_samples_v4 WHERE\n  metric_name='certmanager_certificate_ready_status' AND unix_milli>toUnixTimestamp(now() - INTERVAL 5 MINUTE)*1000\n)",
      "selectedValue": "",
      "showALLOption": false,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    }
  },
