                "unit": "decmbytes",
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "ecs.task.memory.utilized",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "sum",
                        "reduceTo": "last"
                      }
                    ],
                    "filter": {
                      "expression": "(aws.ecs.cluster.name = $ClusterName AND aws.ecs.service.name = $ServiceName)"
                    },
                    "having": {
                      "expression": ""
                    }
                  }
                }
              }
            }
          ]
        }
      },
