{
  "schemaVersion": "v6",
  "image": "data:image/svg+xml;base64,",
  "name": "apm-metrics-uu2dhrb5",
  "tags": [
    {
      "key": "tag",
      "value": "apm"
    },
    {
      "key": "tag",
      "value": "latency"
    },
    {
      "key": "tag",
      "value": "error_rate"
    },
    {
      "key": "tag",
      "value": "throughput"
    }
  ],
  "spec": {
    "display": {
      "name": "APM Metrics",
      "description": "Service APM built from span metrics. Overview: P50/P90/P99 latency, request rate, error percentage, and top operations. DB Metrics: calls per second, average duration, and error percentage by db.system. External calls: per-address rate, error percentage, and duration. Filter by deployment.environment, service.name, and top_level_operation."
    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "deployment.environment",
            "description": "The deployment environment of the service"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "deployment.environment",
              "signal": ""
            }
          },
          "name": "deployment.environment"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "service.name",
            "description": "The service.name value for the application"
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "plugin": {
            "kind": "signoz/DynamicVariable",
            "spec": {
              "name": "service.name",
              "signal": ""
            }
          },
          "name": "service.name"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "top_level_operation",
            "description": "The primary operations for the service are defined here. In a web API service, these are the API endpoints. For services that function as consumers, producers, or clients, these are the names of the entry-point spans."
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT name FROM signoz_traces.top_level_operations WHERE serviceName = $service.name GROUP BY name"
            }
          },
          "name": "top_level_operation"
        }
      }
    ],
    "panels": {
      "02c09a9b-8b9f-45f8-a74c-46cd503ddf5c": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Latency"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "ms",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": "0s"
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 60,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "signoz_latency.bucket",
                              "temporality": "",
                              "timeAggregation": "",
                              "spaceAggregation": "p99",
                              "reduceTo": "avg"
                            }
                          ],
                          "filter": {
                            "expression": "(deployment.environment = $deployment.environment AND service.name = $service.name AND operation IN $top_level_operation)"
                          },
                          "having": {
                            "expression": ""
                          },
                          "legend": "p99"
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
