      "cronjob-observed-failed-runs-selected-range": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Failed Job Run Count",
            "description": "Failed Job runs SigNoz observed during the selected time range."
          },
          "plugin": {
