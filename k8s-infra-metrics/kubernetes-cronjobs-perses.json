                "softMin": null,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 60,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "k8s.job.desired_successful_pods",
                              "temporality": "",
                              "timeAggregation": "max",
                              "spaceAggregation": "sum",
                              "reduceTo": "last"
                            }
                          ],
                          "filter": {
                            "expression": "(k8s.cluster.name IN $k8s.cluster.name AND k8s.namespace.name IN $k8s.namespace.name AND k8s.job.name IN $k8s.job.name)"
                          },
                          "having": {
                            "expression": ""
                          },
                          "legend": "desired successful"
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 60,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "k8s.job.max_parallel_pods",
                              "temporality": "",
                              "timeAggregation": "max",
                              "spaceAggregation": "sum",
                              "reduceTo": "last"
                            }
                          ],
                          "filter": {
                            "expression": "(k8s.cluster.name IN $k8s.cluster.name AND k8s.namespace.name IN $k8s.namespace.name AND k8s.job.name IN $k8s.job.name)"
                          },
                          "having": {
                            "expression": ""
                          },
                          "legend": "max parallel"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
