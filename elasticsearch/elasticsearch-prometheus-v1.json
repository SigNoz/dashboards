      "description": "Current cluster health status - green (healthy), yellow (warning), red (critical)",
      "id": "cluster-health-status",
      "panelTypes": "value",
      "query": {
        "builder": {
          "queryData": [],
          "queryFormulas": []
        },
        "clickhouse_sql": [
          {
            "disabled": false,
            "legend": "",
            "name": "A",
            "query": ""
          }
        ],
        "promql": [
          {
            "disabled": false,
            "legend": "Cluster Status",
            "name": "A",
            "query": "elasticsearch_cluster_health_status"
          }
        ],
        "queryType": 3
      },
      "thresholds": [
        {
          "color": "#EF4444",
          "isEditEnabled": false,
          "label": "Critical",
          "value": 2
        },
        {
          "color": "#F59E0B", 
          "isEditEnabled": false,
          "label": "Warning",
          "value": 1
        },
        {
          "color": "#10B981",
          "isEditEnabled": false,
          "label": "Healthy",
          "value": 0
        }
      ],
      "timePreferance": "GLOBAL_TIME",
      "title": "Cluster Health Status",
      "yAxisUnit": "none"
    },
