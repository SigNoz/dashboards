      "389d43de-99b1-4c35-9589-f7d969abaa9d": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Agents"
          },
          "plugin": {
            "kind": "signoz/TablePanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "formatting": {
                "columnUnits": {
                  "A.avg(duration_nano)": "ns",
                  "A.count()": "none"
                },
                "decimalPrecision": "2"
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "stepInterval": 0,
                    "signal": "traces",
                    "source": "",
                    "aggregations": [
                      {
                        "expression": "count()",
                        "alias": "Requests"
                      },
                      {
                        "expression": "avg(duration_nano)",
                        "alias": "Latency"
                      }
                    ],
                    "filter": {
                      "expression": "service.name in $service_name agent.id EXISTS AND name = 'POST /api/chat'"
                    },
                    "groupBy": [
                      {
                        "name": "agent.id",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "5e66cb8c-2219-47e6-ba71-8f82f9873bc8": {
