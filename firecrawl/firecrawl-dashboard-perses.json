                    "stepInterval": 60,
                    "signal": "traces",
                    "source": "",
                    "aggregations": [
                      {
                        "expression": "count()",
                        "alias": "Calls"
                      },
                      {
                        "expression": "p95(duration_nano)",
                        "alias": "p95 Latency"
                      },
                      {
                        "expression": "avg(duration_nano)",
                        "alias": "Avg Latency"
                      },
                      {
                        "expression": "sum(firecrawl.results)",
