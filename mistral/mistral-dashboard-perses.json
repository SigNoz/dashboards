                        "name": "service.name",
                        "fieldContext": "resource",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "telemetry.sdk.language",
                        "fieldContext": "resource",
                        "fieldDataType": "string"
                      }
                    ],
                    "having": {
                      "expression": ""
                    }
