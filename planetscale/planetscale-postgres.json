      "dynamicVariablesAttribute": "planetscale_database_branch_id",
      "dynamicVariablesSource": "Metrics",
      "queryValue": "",
      "customValue": "",
      "textboxValue": "",
      "multiSelect": true,
      "showALLOption": true,
      "allSelected": true,
      "sort": "ASC",
      "order": 0
    },
    "var_role": {
      "id": "var_role",
