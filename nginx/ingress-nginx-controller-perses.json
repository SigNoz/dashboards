    },
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "controller",
            "description": ""
          },
          "allowAllValue": false,
          "allowMultiple": false,
          "customAllValue": "",
          "capturingRegexp": "",
          "plugin": {
            "kind": "signoz/QueryVariable",
            "spec": {
              "queryValue": "SELECT DISTINCT JSONExtractString(labels, 'controller_pod') FROM signoz_metrics.distributed_time_series_v4\nWHERE metric_name='nginx_ingress_controller_config_hash' AND JSONExtractString(labels, 'controller_namespace')=$namespace AND JSONExtractString(labels, 'controller_class')=$controller_class AND fingerprint GLOBAL IN\n(\n    SELECT DISTINCT fingerprint FROM signoz_metrics.distributed_samples_v4 WHERE\n    metric_name='nginx_ingress_controller_config_hash' AND unix_milli\u003etoUnixTimestamp(now() - INTERVAL 5 MINUTE)*1000\n)"
            }
          },
          "name": "controller"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "controller_class",
