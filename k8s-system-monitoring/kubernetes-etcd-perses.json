{
  "schemaVersion": "v6",
  "name": "kubernetes-etcd-aojf93zi",
  "tags": [
    {
      "key": "tag",
      "value": "kubernetes"
    },
    {
      "key": "tag",
      "value": "control-plane"
    },
    {
      "key": "tag",
      "value": "etcd"
    },
    {
      "key": "tag",
      "value": "prometheus"
